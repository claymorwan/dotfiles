{
  lib,
  fetchurl,
  appimageTools,
  imagemagick,
}:

let
  pname = "omikuji-appimage";
  version = "0.1.0";
  
  src = ./Omikuji-r35.d58baa7-1-anylinux-x86_64.AppImage;

  # fetchurl {
  #   url = "https://github.com/reakjra/omikuji/releases/download/v${version}/Omikuji-x86_64.AppImage";
  #   hash = "sha256-QWhUT/ruU4jwdncYd5B4E4Z8YGRKXIZduiVK7R/gLnI=";
  # };

  appimageContents = appimageTools.extractType2 {
    inherit pname version src;
  };

in 
appimageTools.wrapType2 {
  inherit pname version src;

  extraInstallCommands = ''
    install -Dm444 ${appimageContents}/usr/share/applications/io.github.reakjra.omikuji.desktop \
      $out/share/applications/io.github.reakjra.omikuji.desktop

    install -Dm444 \
      ${appimageContents}/usr/share/icons/hicolor/512x512/apps/io.github.reakjra.omikuji.png \
      $out/share/icons/hicolor/512x512/apps/io.github.reakjra.omikuji.png

    for size in 16 24 32 48 64 128 256; do
      mkdir -p $out/share/icons/hicolor/"$size"x"$size"/apps
      ${lib.getExe imagemagick} \
        ${appimageContents}/usr/share/icons/hicolor/512x512/apps/io.github.reakjra.omikuji.png \
        -resize "$size"x"$size" \
        $out/share/icons/hicolor/"$size"x"$size"/apps/io.github.reakjra.omikuji.png
    done
  '';

  meta = {
    description = "Free and open source instant messaging and VoIP platform.";
    homepage = "https://canary.fluxer.app/";
    license = lib.licenses.agpl3Only;
    maintainers = with lib.maintainers; [ claymorwan ];
  };
}
